        "send": { "callback": "pay:process" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "Booking confirmed!\n\nService: Standard Service\nDate: Sat, Jul 25\nTime: 14:00\nProvider: Alex\nBooking ID: BK-service-2026-07-25-14:00\n\nPayment of $100 processed." } }
