  {
    "name": "Cancelling booking returns to menu",
    "steps": [
      {
        "send": { "callback": "booking:start" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Choose a service:" } }
        ]
      },
      {
        "send": { "callback": "bk:cancel" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "Booking cancelled." } }
        ]
      }
    ]
